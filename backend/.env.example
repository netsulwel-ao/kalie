# ─────────────────────────────────────────────
#  Example .env — copy to .env.dev / .env.staging / .env.prod
#  NEVER commit real values to git
# ─────────────────────────────────────────────

ENVIRONMENT=development
DEBUG=true
API_PORT=8000

POSTGRES_DB=nexus
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://nexus_user:CHANGE_ME@db:5432/nexus

REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

SECRET_KEY=CHANGE_ME_MIN_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_NAME=Nexus Kalie
EMAILS_FROM_EMAIL=

SULIN_API_URL=https://api.sulin.ao
SULIN_API_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CORS_ORIGINS=["http://localhost:5173"]
RATE_LIMIT_PER_MINUTE=60
